require_command() {
  local command_name="$1"

  if ! command -v "${command_name}" >/dev/null 2>&1; then
    echo "Missing required command: ${command_name}" >&2
    exit 1
  fi
}

list_tests() {
  local test_name

  for test_name in "${default_tests[@]}"; do
    echo "${test_name}"
  done
}

list_curated_tests() {
  list_tests
  list_storage_tests
}

list_unsupported_tests() {
  local entry
  local test_name
  local category
  local reason
  local selector
  local imported_test
  local -a imported_tests=()

  for entry in "${unsupported_tests[@]}"; do
    IFS='|' read -r test_name category reason <<<"${entry}"
    printf '%s\t%s\t%s\n' "${test_name}" "${category}" "${reason}"
  done

  while IFS= read -r imported_test; do
    [[ "${imported_test}" != mylite.* ]] || continue
    imported_tests+=("${imported_test}")
  done < <(list_imported_mtr_test_names)

  for entry in "${unsupported_test_selectors[@]}"; do
    IFS='|' read -r selector category reason <<<"${entry}"
    for imported_test in "${imported_tests[@]}"; do
      if [[ "${imported_test}" == ${selector} ]]; then
        printf '%s\t%s\t%s\n' "${imported_test}" "${category}" "${reason}"
      fi
    done
  done
}

list_unsupported_test_names() {
  list_unsupported_tests | cut -f1
}

list_unclassified_tests() {
  local tmp_dir
  local upstream_tests
  local baseline_tests
  local unsupported_tests_file
  local unaccepted_tests

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/mylite-mtr-unclassified.XXXXXX")"
  upstream_tests="${tmp_dir}/upstream"
  baseline_tests="${tmp_dir}/baseline"
  unsupported_tests_file="${tmp_dir}/unsupported"
  unaccepted_tests="${tmp_dir}/unaccepted"

  list_imported_mtr_test_names | grep -v '^mylite[.]' | sort -u >"${upstream_tests}"
  list_tests | sort -u >"${baseline_tests}"
  list_unsupported_test_names | sort -u >"${unsupported_tests_file}"

  comm -23 "${upstream_tests}" "${baseline_tests}" >"${unaccepted_tests}"
  comm -23 "${unaccepted_tests}" "${unsupported_tests_file}"

  rm -rf "${tmp_dir}"
}

list_storage_tests() {
  local test_name

  for test_name in "${storage_tests[@]}"; do
    echo "${test_name}"
  done
}

list_imported_mtr_tests() {
  find "${root_dir}/mariadb/mysql-test/main" -maxdepth 1 -name '*.test' -print
  find "${root_dir}/mariadb/mysql-test/suite" -path '*/t/*.test' -print
}

list_imported_mtr_test_names() {
  local test_file
  local suite_name
  local case_name
  local suite_root="${root_dir}/mariadb/mysql-test/suite/"

  while IFS= read -r test_file; do
    case_name="$(basename "${test_file}" .test)"
    if [[ "${test_file}" == "${root_dir}/mariadb/mysql-test/main/"* ]]; then
      suite_name="main"
    else
      suite_name="${test_file#"${suite_root}"}"
      suite_name="${suite_name%%/*}"
    fi
    echo "${suite_name}.${case_name}"
  done < <(list_imported_mtr_tests)
}

count_lines() {
  wc -l | tr -d '[:space:]'
}

percentage() {
  local part="$1"
  local total="$2"

  awk -v part="${part}" -v total="${total}" \
    'BEGIN { if (total == 0) print "0.00"; else printf "%.2f", part * 100 / total }'
}

coverage_report() {
  local tmp_dir
  local imported_tests
  local upstream_tests
  local mylite_tests
  local baseline_tests
  local storage_tests_file
  local curated_tests_file
  local unsupported_tests_file
  local upstream_count
  local mylite_owned_count
  local imported_count
  local baseline_count
  local storage_count
  local curated_count
  local unsupported_count
  local unsupported_upstream_count
  local unsupported_curated_count
  local baseline_upstream_count
  local baseline_mylite_count
  local storage_mylite_count
  local unaccepted_upstream_count
  local unclassified_upstream_count

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/mylite-mtr-coverage.XXXXXX")"
  imported_tests="${tmp_dir}/imported"
  upstream_tests="${tmp_dir}/upstream"
  mylite_tests="${tmp_dir}/mylite"
  baseline_tests="${tmp_dir}/baseline"
  storage_tests_file="${tmp_dir}/storage"
  curated_tests_file="${tmp_dir}/curated"
  unsupported_tests_file="${tmp_dir}/unsupported"

  list_imported_mtr_test_names | sort -u >"${imported_tests}"
  grep -v '^mylite[.]' "${imported_tests}" >"${upstream_tests}" || true
  grep '^mylite[.]' "${imported_tests}" >"${mylite_tests}" || true
  list_tests | sort -u >"${baseline_tests}"
  list_storage_tests | sort -u >"${storage_tests_file}"
  list_curated_tests | sort -u >"${curated_tests_file}"
  list_unsupported_test_names | sort -u >"${unsupported_tests_file}"

  imported_count="$(count_lines <"${imported_tests}")"
  upstream_count="$(count_lines <"${upstream_tests}")"
  mylite_owned_count="$(count_lines <"${mylite_tests}")"
  baseline_count="$(count_lines <"${baseline_tests}")"
  storage_count="$(count_lines <"${storage_tests_file}")"
  curated_count="$(count_lines <"${curated_tests_file}")"
  unsupported_count="$(count_lines <"${unsupported_tests_file}")"
  unsupported_upstream_count="$(comm -12 "${upstream_tests}" "${unsupported_tests_file}" | count_lines)"
  unsupported_curated_count="$(comm -12 "${curated_tests_file}" "${unsupported_tests_file}" | count_lines)"
  baseline_upstream_count="$(comm -12 "${upstream_tests}" "${baseline_tests}" | count_lines)"
  baseline_mylite_count="$(comm -12 "${mylite_tests}" "${baseline_tests}" | count_lines)"
  storage_mylite_count="$(comm -12 "${mylite_tests}" "${storage_tests_file}" | count_lines)"
  unaccepted_upstream_count=$((upstream_count - baseline_upstream_count))
  unclassified_upstream_count=$((upstream_count - baseline_upstream_count - unsupported_upstream_count))

  if [ "${unsupported_curated_count}" -ne 0 ]; then
    echo "Unsupported MTR inventory overlaps accepted curated tests" >&2
    rm -rf "${tmp_dir}"
    exit 1
  fi

  cat <<EOF
MTR coverage inventory
imported-test-files=${imported_count}
upstream-test-files=${upstream_count}
mylite-owned-test-files=${mylite_owned_count}
accepted-baseline-tests=${baseline_count}
accepted-baseline-upstream-tests=${baseline_upstream_count}
accepted-baseline-mylite-tests=${baseline_mylite_count}
accepted-storage-mylite-tests=${storage_mylite_count}
accepted-storage-tests=${storage_count}
accepted-total-tests=${curated_count}
known-unsupported-tests=${unsupported_count}
known-unsupported-upstream-tests=${unsupported_upstream_count}
accepted-upstream-percent=$(percentage "${baseline_upstream_count}" "${upstream_count}")
unaccepted-upstream-test-files=${unaccepted_upstream_count}
unclassified-upstream-test-files=${unclassified_upstream_count}
EOF

  rm -rf "${tmp_dir}"
}

prepare_mtr_build() {
  if ! mtr_cache_ready; then
    PROFILE="${mtr_profile}" BUILD_DIR="${build_dir}" \
      "${root_dir}/tools/mariadb-embedded-build" configure
  fi

  if ! mtr_cache_ready; then
    echo "MTR build cache does not match the required MyLite MTR smoke profile" >&2
    exit 1
  fi

  BUILD_DIR="${build_dir}" "${root_dir}/tools/mariadb-embedded-build" \
    build "${mtr_targets[@]}"
}

mtr_cache_ready() {
  local entry

  if [ ! -f "${build_dir}/CMakeCache.txt" ]; then
    return 1
  fi

  for entry in "${mtr_required_cache_entries[@]}"; do
    if ! grep -qxF "${entry}" "${build_dir}/CMakeCache.txt"; then
      return 1
    fi
  done
}

assert_test_passed() {
  local output_file="$1"
  local suite_name="$2"
  local case_name="$3"

  if ! test_reported_passed "${output_file}" "${suite_name}" "${case_name}"; then
    echo "Expected ${suite_name}.${case_name} to report an MTR pass" >&2
    return 1
  fi
}

test_reported_passed() {
  local output_file="$1"
  local suite_name="$2"
  local case_name="$3"
  local pass_pattern

  pass_pattern="^[[:space:]]*${suite_name}\\.${case_name}"
  pass_pattern+="([[:space:]]+'[^']+')?[[:space:]]+\\[ pass \\]"
  grep -Eq "${pass_pattern}" "${output_file}"
}

test_reported_skipped() {
  local output_file="$1"
  local suite_name="$2"
  local case_name="$3"
  local skip_pattern

  skip_pattern="^[[:space:]]*${suite_name}\\.${case_name}"
  skip_pattern+="([[:space:]]+'[^']+')?[[:space:]]+\\[ skipped \\]"
  grep -Eq "${skip_pattern}" "${output_file}"
}

run_tests() {
  local tests=("$@")

  if [ "${#tests[@]}" -eq 0 ]; then
    tests=("${default_tests[@]}")
  fi

  configure_baseline_mtr_context
  prepare_mtr_build
  run_mtr_suite_batches "${tests[@]}"
}

run_storage_tests() {
  local tests=("$@")

  if [ "${#tests[@]}" -eq 0 ]; then
    tests=("${storage_tests[@]}")
  fi

  configure_storage_mtr_context
  prepare_storage_primary_file
  prepare_mtr_build
  run_mtr_suite_batches "${tests[@]}"
}

configure_baseline_mtr_context() {
  build_dir="${BUILD_DIR:-"${root_dir}/build/mariadb-mtr-smoke"}"
  mtr_profile="${PROFILE:-"${root_dir}/cmake/mariadb-mtr-smoke.cmake"}"
  mtr_default_storage_engine="Aria"
  mtr_primary_file=""
  mtr_extra_mysqld_args=()
  mtr_required_cache_entries=("${baseline_mtr_required_cache_entries[@]}")
}

configure_storage_mtr_context() {
  build_dir="${storage_build_dir}"
  mtr_profile="${storage_mtr_profile}"
  mtr_default_storage_engine="Aria"
  mtr_primary_file="${storage_primary_file}"
  mtr_extra_mysqld_args=()
  mtr_required_cache_entries=("${storage_mtr_required_cache_entries[@]}")
}

prepare_storage_primary_file() {
  prepare_storage_init_tool

  mkdir -p "$(dirname "${storage_primary_file}")"
  rm -f \
    "${storage_primary_file}" \
    "${storage_primary_file}-journal" \
    "${storage_primary_file}-journal.rewrite" \
    "${storage_primary_file}-transaction-journal" \
    "${storage_primary_file}-transaction-journal.rewrite"
  "${storage_init_tool}" "${storage_primary_file}"
}

prepare_storage_init_tool() {
  if [ -x "${storage_init_tool}" ]; then
    return
  fi

  cmake --preset dev
  cmake --build --preset dev --target mylite_storage_init

  if [ ! -x "${storage_init_tool}" ]; then
    echo "Could not find built mylite-storage-init at ${storage_init_tool}" >&2
    exit 1
  fi
}

run_mtr_suite_batches() {
  local tests=("$@")
  local suite_names=()
  local suite_cases=()
  local test_name
  local suite_name
  local case_name
  local existing_suite
  local suite_seen
  local output_file

  for test_name in "${tests[@]}"; do
    if [[ "${test_name}" != *.* ]]; then
      echo "Expected suite.test name, got: ${test_name}" >&2
      exit 2
    fi

    suite_name="${test_name%%.*}"
    suite_seen=0
    for existing_suite in ${suite_names[@]+"${suite_names[@]}"}; do
      if [ "${existing_suite}" = "${suite_name}" ]; then
        suite_seen=1
        break
      fi
    done
    if [ "${suite_seen}" -eq 0 ]; then
      suite_names+=("${suite_name}")
    fi
  done

  for suite_name in ${suite_names[@]+"${suite_names[@]}"}; do
    suite_cases=()
    for test_name in "${tests[@]}"; do
      if [ "${test_name%%.*}" = "${suite_name}" ]; then
        suite_cases+=("${test_name#*.}")
      fi
    done

    output_file="$(mktemp "${TMPDIR:-/tmp}/mylite-mtr-output.XXXXXX")"
    if ! run_mtr_suite_cases "${suite_name}" "${output_file}" stream "" "${suite_cases[@]}"; then
      rm -f "${output_file}"
      exit 1
    fi

    for case_name in "${suite_cases[@]}"; do
      if ! assert_test_passed "${output_file}" "${suite_name}" "${case_name}"; then
        rm -f "${output_file}"
        exit 1
      fi
    done

    rm -f "${output_file}"
  done
}

probe_tests() {
  local tests=("$@")

  if [ "${#tests[@]}" -eq 0 ]; then
    echo "Expected at least one suite.test name for probe" >&2
    exit 1
  fi

  configure_baseline_mtr_context
  prepare_mtr_build
  probe_with_current_mtr_context "${tests[@]}"
}

probe_storage_tests() {
  local tests=("$@")

  if [ "${#tests[@]}" -eq 0 ]; then
    echo "Expected at least one suite.test name for probe-storage" >&2
    exit 1
  fi

  configure_storage_mtr_context
  prepare_storage_primary_file
  prepare_mtr_build
  probe_with_current_mtr_context "${tests[@]}"
}

probe_with_current_mtr_context() {
  local tests=("$@")
  local failures=0
  local passed_count=0
  local failed_count=0
  local skipped_count=0
  local passed_tests=""
  local failed_tests=""
  local skipped_tests=""
  local reject_baseline_file
  local test_name
  local output_file
  local probe_status

  reject_baseline_file="$(mktemp "${TMPDIR:-/tmp}/mylite-mtr-rejects.XXXXXX")"
  snapshot_reject_files "${reject_baseline_file}"

  for test_name in "${tests[@]}"; do
    output_file="$(mktemp "${TMPDIR:-/tmp}/mylite-mtr-output.XXXXXX")"
    if probe_mtr_case \
      "${test_name}" \
      "${output_file}" \
      "${mtr_probe_testcase_timeout_minutes}"; then
      probe_status=0
    else
      probe_status=$?
    fi
    case "${probe_status}" in
      0)
        echo "PASS ${test_name}"
        passed_count=$((passed_count + 1))
        passed_tests+="${test_name}"$'\n'
        ;;
      2)
        echo "SKIP ${test_name}"
        print_probe_failure_summary "${output_file}"
        failures=1
        skipped_count=$((skipped_count + 1))
        skipped_tests+="${test_name}"$'\n'
        ;;
      *)
        echo "FAIL ${test_name}"
        print_probe_failure_summary "${output_file}"
        failures=1
        failed_count=$((failed_count + 1))
        failed_tests+="${test_name}"$'\n'
        ;;
    esac
    cleanup_new_reject_files "${reject_baseline_file}"
    rm -f "${output_file}"
  done

  print_probe_summary \
    "${passed_count}" \
    "${failed_count}" \
    "${skipped_count}" \
    "${passed_tests}" \
    "${failed_tests}" \
    "${skipped_tests}"
  rm -f "${reject_baseline_file}"
  return "${failures}"
}

snapshot_reject_files() {
  local output_file="$1"

  find "${root_dir}/mariadb/mysql-test" -name '*.reject' -print >"${output_file}"
}

cleanup_new_reject_files() {
  local baseline_file="$1"
  local reject_file

  while IFS= read -r reject_file; do
    if ! grep -qxF "${reject_file}" "${baseline_file}"; then
      rm -f "${reject_file}"
    fi
  done < <(find "${root_dir}/mariadb/mysql-test" -name '*.reject' -print)
}

run_mtr_case() {
  local test_name="$1"
  local output_file="$2"
  local output_mode="$3"
  local testcase_timeout_minutes="${4:-}"
  local suite_name
  local case_name
  local testcase_timeout_args=()

  if [[ "${test_name}" != *.* ]]; then
    echo "Expected suite.test name, got: ${test_name}" >&2
    return 2
  fi

  suite_name="${test_name%%.*}"
  case_name="${test_name#*.}"

  if ! run_mtr_suite_cases \
    "${suite_name}" \
    "${output_file}" \
    "${output_mode}" \
    "${testcase_timeout_minutes}" \
    "${case_name}"; then
    return 1
  fi

  if [ "${output_mode}" = quiet ]; then
    assert_test_passed "${output_file}" "${suite_name}" "${case_name}" \
      >>"${output_file}" 2>&1
    return $?
  fi

  assert_test_passed "${output_file}" "${suite_name}" "${case_name}"
}

probe_mtr_case() {
  local test_name="$1"
  local output_file="$2"
  local testcase_timeout_minutes="${3:-}"
  local suite_name
  local case_name

  if [[ "${test_name}" != *.* ]]; then
    echo "Expected suite.test name, got: ${test_name}" >&2
    return 1
  fi

  suite_name="${test_name%%.*}"
  case_name="${test_name#*.}"

  if ! run_mtr_suite_cases \
    "${suite_name}" \
    "${output_file}" \
    quiet \
    "${testcase_timeout_minutes}" \
    "${case_name}"; then
    return 1
  fi

  if test_reported_passed "${output_file}" "${suite_name}" "${case_name}"; then
    return 0
  fi

  if test_reported_skipped "${output_file}" "${suite_name}" "${case_name}"; then
    return 2
  fi

  assert_test_passed "${output_file}" "${suite_name}" "${case_name}" \
    >>"${output_file}" 2>&1 || true
  return 1
}

run_mtr_suite_cases() {
  local suite_name="$1"
  local output_file="$2"
  local output_mode="$3"
  local testcase_timeout_minutes="${4:-}"
  local do_test_pattern
  local testcase_timeout_args=()

  shift 4

  if [ -n "${testcase_timeout_minutes}" ]; then
    testcase_timeout_args=("--testcase-timeout=${testcase_timeout_minutes}")
  fi

  do_test_pattern="$(build_mtr_case_pattern "$@")"

  if [ "${output_mode}" = quiet ]; then
    if ! (
      cd "${build_dir}/mysql-test"
      MTR_BUILD_THREAD="${mtr_build_thread}" \
      MYLITE_MTR_WITHOUT_NATIVE_MYISAM_TOOLS=1 \
      MYLITE_MTR_DEFAULT_STORAGE_ENGINE="${mtr_default_storage_engine}" \
      MYLITE_MTR_PRIMARY_FILE="${mtr_primary_file}" \
        perl ./mariadb-test-run.pl \
          --embedded-server \
          --skip-rpl \
          --force \
          --mysqld=--default-storage-engine="${mtr_default_storage_engine}" \
          ${mtr_extra_mysqld_args[@]+"${mtr_extra_mysqld_args[@]}"} \
          --suite="${suite_name}" \
          --do-test="${do_test_pattern}" \
          ${testcase_timeout_args[@]+"${testcase_timeout_args[@]}"} \
          --max-test-fail=1 >"${output_file}" 2>&1
    ); then
      return 1
    fi
    return 0
  fi

  if ! (
    cd "${build_dir}/mysql-test"
    MTR_BUILD_THREAD="${mtr_build_thread}" \
    MYLITE_MTR_WITHOUT_NATIVE_MYISAM_TOOLS=1 \
    MYLITE_MTR_DEFAULT_STORAGE_ENGINE="${mtr_default_storage_engine}" \
    MYLITE_MTR_PRIMARY_FILE="${mtr_primary_file}" \
      perl ./mariadb-test-run.pl \
        --embedded-server \
        --skip-rpl \
        --force \
        --mysqld=--default-storage-engine="${mtr_default_storage_engine}" \
        ${mtr_extra_mysqld_args[@]+"${mtr_extra_mysqld_args[@]}"} \
        --suite="${suite_name}" \
        --do-test="${do_test_pattern}" \
        ${testcase_timeout_args[@]+"${testcase_timeout_args[@]}"} \
        --max-test-fail=1 | tee "${output_file}"
  ); then
    return 1
  fi
}

build_mtr_case_pattern() {
  local pattern="^("
  local separator=""
  local case_name

  for case_name in "$@"; do
    pattern+="${separator}"
    pattern+="$(escape_mtr_case_pattern "${case_name}")"
    separator="|"
  done

  pattern+=")$"
  echo "${pattern}"
}

escape_mtr_case_pattern() {
  printf '%s' "$1" | sed -e 's/[][\\.^$*+?{}()|]/\\&/g'
}

print_probe_failure_summary() {
  local output_file="$1"

  tail -n 40 "${output_file}" >&2
}

print_probe_summary() {
  local passed_count="$1"
  local failed_count="$2"
  local skipped_count="$3"
  local passed_tests="$4"
  local failed_tests="$5"
  local skipped_tests="$6"

  echo "Probe summary: ${passed_count} passed, ${failed_count} failed, ${skipped_count} skipped"
  if [ "${passed_count}" -gt 0 ]; then
    printf 'Passed tests:\n%s' "${passed_tests}"
  fi
  if [ "${failed_count}" -gt 0 ]; then
    printf 'Failed tests:\n%s' "${failed_tests}"
  fi
  if [ "${skipped_count}" -gt 0 ]; then
    printf 'Skipped tests:\n%s' "${skipped_tests}"
  fi
}

require_command cmake
require_command perl

command_name="${1:-run}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "${command_name}" in
  list)
    list_tests
    ;;
  coverage)
    coverage_report
    ;;
  run)
    run_tests "$@"
    ;;
  probe)
    probe_tests "$@"
    ;;
  list-storage)
    list_storage_tests
    ;;
  list-unsupported)
    list_unsupported_tests
    ;;
  list-unclassified)
    list_unclassified_tests
    ;;
  run-storage)
    run_storage_tests "$@"
    ;;
  probe-storage)
    probe_storage_tests "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
