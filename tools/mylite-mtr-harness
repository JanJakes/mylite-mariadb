#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
build_dir="${BUILD_DIR:-"${root_dir}/build/mariadb-mtr-smoke"}"
mtr_profile="${PROFILE:-"${root_dir}/cmake/mariadb-mtr-smoke.cmake"}"
mtr_build_thread="${MTR_BUILD_THREAD:-auto}"
default_tests=(
  mylite.bootstrap_schema
  main.cast
  main.case
  main.bigint
  main.type_ranges
  main.type_num
  main.type_uint
  main.type_year
  main.adddate_454
  main.date_formats
  main.datetime_456
  main.in_datetime_241
  main.str_to_datetime_457
  main.func_time_round
  main.func_sapdb
  main.func_time_64
  main.func_timestamp
  main.type_date_round
  main.type_datetime_round
  main.type_time_round
  main.type_time_6065
  main.type_timestamp_round
  main.brackets
  main.comments
  main.compare
  main.func_in
  main.ctype_ascii
  main.ctype_cp850
  main.ctype_cp866
  main.ctype_hebrew
  main.ctype_utf32_def
  main.ctype_collate_column
  main.ctype_collate_context
  main.ctype_collate_database
  main.ctype_collate_implicit
  main.ctype_collate_implicit_def
  main.ctype_collate_table
  main.ctype_errors
  main.count_distinct
  main.sum_distinct
  main.func_equal
  main.func_op
  main.func_bit
  main.func_concat
  main.func_default
  main.func_extract
  main.func_format
  main.func_replace
  main.func_regexp
  main.func_regexp_pcre
  main.func_weight_string
  main.func_kdf
  main.func_encrypt_nossl
)

usage() {
  cat <<EOF
Usage: tools/mylite-mtr-harness [list|run] [suite.test...]

Commands:
  list       Show curated MariaDB MTR smoke tests.
  run        Build the MTR smoke prerequisites and run exact selected tests.
             Defaults to the curated smoke list.

Environment:
  BUILD_DIR          MariaDB build directory. Defaults to build/mariadb-mtr-smoke.
  PROFILE            Initial CMake cache. Defaults to cmake/mariadb-mtr-smoke.cmake.
  MTR_BUILD_THREAD  MTR build thread/port block. Defaults to auto.
EOF
}

mtr_targets=(
  libmariadbd.a
  mariadbd
  mariadb-test-embedded
  mariadb-client-test-embedded
  my_safe_process
  mariadb-admin
  mariadb
  mariadb-plugin
  mariadb-conv
  mariadb-check
  mariadb-dump
  mariadb-slap
  mariadb-import
  mariadb-show
  mariadb-binlog
  mariadb-upgrade
  my_print_defaults
  aria_chk
  aria_pack
  perror
  mariadb-tzinfo-to-sql
  replace
)

mtr_required_cache_entries=(
  "MYLITE_WITH_VIEW_RUNTIME:BOOL=ON"
  "MYLITE_WITH_STORED_PROGRAM_RUNTIME:BOOL=ON"
  "MYLITE_WITH_TRIGGER_RUNTIME:BOOL=ON"
  "MYLITE_WITH_BINLOG_SYSVARS:BOOL=ON"
  "MYLITE_WITH_NATIVE_MYISAM_STORAGE_ENGINE:BOOL=OFF"
  "MYLITE_WITH_NATIVE_MYISAMMRG_STORAGE_ENGINE:BOOL=OFF"
  "MYLITE_WITH_CSV_STORAGE_ENGINE:BOOL=OFF"
  "PLUGIN_CSV:STRING=NO"
  "PLUGIN_INNOBASE:STRING=NO"
  "PLUGIN_PARTITION:STRING=NO"
)

require_command() {
  local command_name="$1"

  if ! command -v "${command_name}" >/dev/null 2>&1; then
    echo "Missing required command: ${command_name}" >&2
    exit 1
  fi
}

list_tests() {
  local test_name

  for test_name in "${default_tests[@]}"; do
    echo "${test_name}"
  done
}

prepare_mtr_build() {
  local target

  if ! mtr_cache_ready; then
    PROFILE="${mtr_profile}" BUILD_DIR="${build_dir}" \
      "${root_dir}/tools/mariadb-embedded-build" configure
  fi

  if ! mtr_cache_ready; then
    echo "MTR build cache does not match the required MyLite MTR smoke profile" >&2
    exit 1
  fi

  BUILD_DIR="${build_dir}" "${root_dir}/tools/mariadb-embedded-build" build

  for target in "${mtr_targets[@]}"; do
    cmake --build "${build_dir}" --target "${target}"
  done
}

mtr_cache_ready() {
  local entry

  if [ ! -f "${build_dir}/CMakeCache.txt" ]; then
    return 1
  fi

  for entry in "${mtr_required_cache_entries[@]}"; do
    if ! grep -qxF "${entry}" "${build_dir}/CMakeCache.txt"; then
      return 1
    fi
  done
}

assert_test_passed() {
  local output_file="$1"
  local suite_name="$2"
  local case_name="$3"
  local pass_pattern

  pass_pattern="^[[:space:]]*${suite_name}\\.${case_name}"
  pass_pattern+="([[:space:]]+'[^']+')?[[:space:]]+\\[ pass \\]"
  if ! grep -Eq "${pass_pattern}" "${output_file}"; then
    echo "Expected ${suite_name}.${case_name} to report an MTR pass" >&2
    return 1
  fi
}

run_tests() {
  local tests=("$@")
  local test_name
  local suite_name
  local case_name
  local output_file

  if [ "${#tests[@]}" -eq 0 ]; then
    tests=("${default_tests[@]}")
  fi

  prepare_mtr_build

  for test_name in "${tests[@]}"; do
    if [[ "${test_name}" != *.* ]]; then
      echo "Expected suite.test name, got: ${test_name}" >&2
      exit 1
    fi

    suite_name="${test_name%%.*}"
    case_name="${test_name#*.}"
    output_file="$(mktemp "${TMPDIR:-/tmp}/mylite-mtr-output.XXXXXX")"
    if ! (
      cd "${build_dir}/mysql-test"
      MTR_BUILD_THREAD="${mtr_build_thread}" \
      MYLITE_MTR_WITHOUT_NATIVE_MYISAM_TOOLS=1 \
      MYLITE_MTR_DEFAULT_STORAGE_ENGINE=Aria \
        perl ./mariadb-test-run.pl \
          --embedded-server \
          --skip-rpl \
          --force \
          --mysqld=--default-storage-engine=Aria \
          --suite="${suite_name}" \
          --do-test="^${case_name}$" \
          --max-test-fail=1 | tee "${output_file}"
    ); then
      rm -f "${output_file}"
      exit 1
    fi

    if ! assert_test_passed "${output_file}" "${suite_name}" "${case_name}"; then
      rm -f "${output_file}"
      exit 1
    fi
    rm -f "${output_file}"
  done
}

require_command cmake
require_command perl

command_name="${1:-run}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "${command_name}" in
  list)
    list_tests
    ;;
  run)
    run_tests "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
