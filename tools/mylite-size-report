#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
report="${MYLITE_SIZE_REPORT:-"${root_dir}/build/mylite-size-report.md"}"
mariadb_build_dir="${MARIADB_BUILD_DIR:-"${root_dir}/build/mariadb-embedded"}"
storage_mariadb_build_dir="${STORAGE_MARIADB_BUILD_DIR:-"${root_dir}/build/mariadb-mylite-storage-smoke"}"
embedded_build_dir="${MYLITE_EMBEDDED_BUILD_DIR:-"${root_dir}/build/embedded-dev"}"
storage_build_dir="${MYLITE_STORAGE_SMOKE_BUILD_DIR:-"${root_dir}/build/storage-smoke-dev"}"
artifact_count=0

usage() {
  cat <<EOF
Usage: tools/mylite-size-report [report]

Commands:
  report     Write a Markdown size report. This is the default.

Environment:
  MYLITE_SIZE_REPORT             Report path. Defaults to build/mylite-size-report.md.
  MARIADB_BUILD_DIR              MariaDB embedded build directory.
  STORAGE_MARIADB_BUILD_DIR      MariaDB storage-smoke build directory.
  MYLITE_EMBEDDED_BUILD_DIR      MyLite embedded-dev build directory.
  MYLITE_STORAGE_SMOKE_BUILD_DIR MyLite storage-smoke-dev build directory.
EOF
}

require_command() {
  local command_name="$1"

  if ! command -v "${command_name}" >/dev/null 2>&1; then
    echo "Missing required command: ${command_name}" >&2
    exit 1
  fi
}

write_report() {
  mkdir -p "$(dirname "${report}")"
  {
    echo "# MyLite Size Report"
    echo
    echo "Generated by \`tools/mylite-size-report\`."
    echo
    echo "| Artifact | Type | Path | Size | Stripped Size | Members | Global Symbols | Status |"
    echo "| --- | --- | --- | ---: | ---: | ---: | ---: | --- |"
  } >"${report}"

  append_archive_row \
    "MariaDB embedded archive" \
    "${mariadb_build_dir}/libmysqld/libmariadbd.a"
  append_archive_row \
    "MariaDB storage-smoke archive" \
    "${storage_mariadb_build_dir}/libmysqld/libmariadbd.a"
  append_linked_row \
    "Embedded open-close smoke" \
    "${embedded_build_dir}/packages/libmylite/mylite_embedded_open_close_test"
  append_linked_row \
    "Embedded exec smoke" \
    "${embedded_build_dir}/packages/libmylite/mylite_embedded_exec_test"
  append_linked_row \
    "Embedded statement smoke" \
    "${embedded_build_dir}/packages/libmylite/mylite_embedded_statement_test"
  append_linked_row \
    "Embedded warning smoke" \
    "${embedded_build_dir}/packages/libmylite/mylite_embedded_warning_test"
  append_linked_row \
    "Embedded comparison smoke" \
    "${embedded_build_dir}/packages/libmylite/mylite_embedded_comparison_test"
  append_linked_row \
    "Storage-smoke open-close smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_open_close_test"
  append_linked_row \
    "Storage-smoke exec smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_exec_test"
  append_linked_row \
    "Storage-smoke statement smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_statement_test"
  append_linked_row \
    "Storage-smoke warning smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_warning_test"
  append_linked_row \
    "Storage-smoke comparison smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_comparison_test"
  append_linked_row \
    "Storage-engine smoke" \
    "${storage_build_dir}/packages/libmylite/mylite_embedded_storage_engine_test"

  echo "report=${report}"
  if [ "${artifact_count}" -eq 0 ]; then
    echo "No size artifacts were found. Build the embedded presets first." >&2
    return 1
  fi
}

append_archive_row() {
  local name="$1"
  local path="$2"
  local members
  local size

  if [ ! -f "${path}" ]; then
    append_missing_row "${name}" "archive" "${path}"
    return
  fi

  artifact_count=$((artifact_count + 1))
  size="$(format_size "$(file_size "${path}")")"
  members="$(archive_member_count "${path}")"
  printf '| %s | archive | `%s` | %s | n/a | %s | n/a | present |\n' \
    "${name}" \
    "${path#${root_dir}/}" \
    "${size}" \
    "${members}" \
    >>"${report}"
}

append_linked_row() {
  local name="$1"
  local path="$2"
  local global_symbols
  local size
  local stripped_size

  if [ ! -f "${path}" ]; then
    append_missing_row "${name}" "linked" "${path}"
    return
  fi

  artifact_count=$((artifact_count + 1))
  size="$(format_size "$(file_size "${path}")")"
  stripped_size="$(stripped_file_size "${path}")"
  global_symbols="$(defined_global_symbol_count "${path}")"
  printf '| %s | linked | `%s` | %s | %s | n/a | %s | present |\n' \
    "${name}" \
    "${path#${root_dir}/}" \
    "${size}" \
    "${stripped_size}" \
    "${global_symbols}" \
    >>"${report}"
}

append_missing_row() {
  local name="$1"
  local type="$2"
  local path="$3"

  printf '| %s | %s | `%s` | n/a | n/a | n/a | n/a | missing |\n' \
    "${name}" \
    "${type}" \
    "${path#${root_dir}/}" \
    >>"${report}"
}

archive_member_count() {
  local path="$1"

  require_command ar
  ar -t "${path}" | wc -l | tr -d '[:space:]'
}

stripped_file_size() {
  local path="$1"
  local stripped
  local temp_dir

  if ! command -v strip >/dev/null 2>&1; then
    echo "n/a"
    return
  fi

  temp_dir="$(mktemp -d)"
  stripped="${temp_dir}/$(basename "${path}")"
  cp -p "${path}" "${stripped}"

  if strip --strip-all "${stripped}" >/dev/null 2>&1 ||
    strip -x "${stripped}" >/dev/null 2>&1 ||
    strip "${stripped}" >/dev/null 2>&1; then
    format_size "$(file_size "${stripped}")"
  else
    echo "n/a"
  fi

  rm -rf "${temp_dir}"
}

defined_global_symbol_count() {
  local path="$1"
  local symbols

  if ! command -v nm >/dev/null 2>&1; then
    echo "n/a"
    return
  fi

  if [ "$(uname -s)" = "Darwin" ]; then
    if symbols="$(nm -gU "${path}" 2>/dev/null)"; then
      printf '%s\n' "${symbols}" | awk 'NF { count++ } END { print count + 0 }'
    else
      echo "n/a"
    fi
    return
  fi

  if symbols="$(nm -D --defined-only "${path}" 2>/dev/null)" ||
    symbols="$(nm -g --defined-only "${path}" 2>/dev/null)"; then
    printf '%s\n' "${symbols}" | awk 'NF { count++ } END { print count + 0 }'
  else
    echo "n/a"
  fi
}

format_size() {
  local bytes="$1"
  local mib

  mib="$(awk -v bytes="${bytes}" 'BEGIN { printf "%.2f", bytes / 1048576 }')"
  printf '%s bytes / %s MiB' "${bytes}" "${mib}"
}

file_size() {
  local path="$1"

  if size="$(stat -f %z "${path}" 2>/dev/null)"; then
    echo "${size}"
    return
  fi

  stat -c %s "${path}"
}

command_name="${1:-report}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "${command_name}" in
  report)
    write_report
    ;;
  -h | --help | help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
