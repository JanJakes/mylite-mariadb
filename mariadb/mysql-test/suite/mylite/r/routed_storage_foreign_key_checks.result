drop database if exists mylite_mtr_foreign_key_checks;
create database mylite_mtr_foreign_key_checks;
use mylite_mtr_foreign_key_checks;
set session sql_mode='NO_ENGINE_SUBSTITUTION';
set session default_storage_engine=MYLITE;
set session enforce_storage_engine=MYLITE;
set session use_stat_tables=NEVER;
create table checks_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=InnoDB;
create table checks_child (
id int not null primary key,
parent_id int not null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint checks_child_parent_fk
foreign key (parent_id) references checks_parent (id)
) engine=InnoDB;
create table mylite_checks_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=MYLITE;
create table mylite_checks_child (
id int not null primary key,
parent_id int not null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint mylite_checks_child_parent_fk
foreign key (parent_id) references mylite_checks_parent (id)
) engine=MYLITE;
set foreign_key_checks=0;
select @@foreign_key_checks as checks_enabled;
checks_enabled
0
