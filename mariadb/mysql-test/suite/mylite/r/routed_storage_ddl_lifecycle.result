id	title	rating
2	mylite-replace-beta	5
drop table mylite_replace_plain_posts, mylite_ctas_posts,
renamed_mylite_like_posts, mylite_lifecycle_posts, replace_ctas_posts,
replace_like_posts, replace_plain_posts, ctas_posts, renamed_like_posts,
lifecycle_posts;
drop database mylite_mtr_ddl_lifecycle;
