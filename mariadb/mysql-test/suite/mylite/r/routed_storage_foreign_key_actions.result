create table cascade_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=InnoDB;
create table cascade_child (
id int not null primary key,
parent_id int not null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint cascade_child_parent_fk
foreign key (parent_id) references cascade_parent (id)
on delete cascade on update cascade
) engine=InnoDB;
create table mylite_cascade_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=MYLITE;
create table mylite_cascade_child (
id int not null primary key,
parent_id int not null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint mylite_cascade_child_parent_fk
foreign key (parent_id) references mylite_cascade_parent (id)
on delete cascade on update cascade
) engine=MYLITE;
show create table cascade_child;
Table	Create Table
cascade_child	CREATE TABLE `cascade_child` (
  `id` int(11) NOT NULL,
  `parent_id` int(11) NOT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  KEY `parent_idx` (`parent_id`),
  CONSTRAINT `cascade_child_parent_fk` FOREIGN KEY (`parent_id`) REFERENCES `cascade_parent` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
show create table mylite_cascade_child;
Table	Create Table
mylite_cascade_child	CREATE TABLE `mylite_cascade_child` (
  `id` int(11) NOT NULL,
  `parent_id` int(11) NOT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  KEY `parent_idx` (`parent_id`),
  CONSTRAINT `mylite_cascade_child_parent_fk` FOREIGN KEY (`parent_id`) REFERENCES `mylite_cascade_parent` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=MYLITE DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
