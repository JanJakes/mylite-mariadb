drop database if exists mylite_mtr_foreign_key_actions;
create database mylite_mtr_foreign_key_actions;
use mylite_mtr_foreign_key_actions;
set session sql_mode='NO_ENGINE_SUBSTITUTION';
set session default_storage_engine=MYLITE;
set session enforce_storage_engine=MYLITE;
set session use_stat_tables=NEVER;
create table setnull_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=InnoDB;
create table setnull_child (
id int not null primary key,
parent_id int null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint setnull_child_parent_fk
foreign key (parent_id) references setnull_parent (id)
on delete set null on update set null
) engine=InnoDB;
create table mylite_setnull_parent (
id int not null primary key,
title varchar(32) not null unique
) engine=MYLITE;
create table mylite_setnull_child (
id int not null primary key,
parent_id int null,
title varchar(32) not null,
key parent_idx (parent_id),
constraint mylite_setnull_child_parent_fk
foreign key (parent_id) references mylite_setnull_parent (id)
on delete set null on update set null
) engine=MYLITE;
show create table setnull_child;
Table	Create Table
setnull_child	CREATE TABLE `setnull_child` (
  `id` int(11) NOT NULL,
  `parent_id` int(11) DEFAULT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  KEY `parent_idx` (`parent_id`),
  CONSTRAINT `setnull_child_parent_fk` FOREIGN KEY (`parent_id`) REFERENCES `setnull_parent` (`id`) ON DELETE SET NULL ON UPDATE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
show create table mylite_setnull_child;
Table	Create Table
mylite_setnull_child	CREATE TABLE `mylite_setnull_child` (
  `id` int(11) NOT NULL,
  `parent_id` int(11) DEFAULT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  KEY `parent_idx` (`parent_id`),
  CONSTRAINT `mylite_setnull_child_parent_fk` FOREIGN KEY (`parent_id`) REFERENCES `mylite_setnull_parent` (`id`) ON DELETE SET NULL ON UPDATE SET NULL
) ENGINE=MYLITE DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
insert into setnull_parent values (1, 'parent');
insert into setnull_child values (10, 1, 'child');
insert into setnull_parent values (3, 'delete-parent');
insert into setnull_child values (11, 3, 'delete-child');
insert into mylite_setnull_parent values (1, 'mylite-parent');
insert into mylite_setnull_child values (10, 1, 'mylite-child');
insert into mylite_setnull_parent values (3, 'mylite-delete-parent');
insert into mylite_setnull_child values (11, 3, 'mylite-delete-child');
update setnull_parent set id = 2 where id = 1;
update mylite_setnull_parent set id = 2 where id = 1;
select id, parent_id is null as parent_is_null
from setnull_child where id = 10;
id	parent_is_null
10	1
select id, parent_id is null as parent_is_null
from mylite_setnull_child where id = 10;
id	parent_is_null
10	1
delete from setnull_parent where id = 2;
delete from setnull_parent where id = 3;
delete from mylite_setnull_parent where id = 2;
delete from mylite_setnull_parent where id = 3;
select id, parent_id is null as parent_is_null
from setnull_child order by id;
id	parent_is_null
10	1
11	1
select id, parent_id is null as parent_is_null
from mylite_setnull_child order by id;
id	parent_is_null
