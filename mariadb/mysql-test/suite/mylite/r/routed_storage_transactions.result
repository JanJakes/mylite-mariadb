drop database if exists mylite_mtr_transactions;
create database mylite_mtr_transactions;
use mylite_mtr_transactions;
set session sql_mode='NO_ENGINE_SUBSTITUTION';
set session default_storage_engine=MYLITE;
set session enforce_storage_engine=MYLITE;
set session use_stat_tables=NEVER;
create table tx (
id int not null primary key,
title varchar(32) not null,
unique key title_key (title)
) engine=InnoDB;
create table tx_mylite (
id int not null primary key,
title varchar(32) not null,
unique key title_key (title)
) engine=MYLITE;
show create table tx;
Table	Create Table
tx	CREATE TABLE `tx` (
  `id` int(11) NOT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `title_key` (`title`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
show create table tx_mylite;
Table	Create Table
tx_mylite	CREATE TABLE `tx_mylite` (
  `id` int(11) NOT NULL,
  `title` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `title_key` (`title`)
) ENGINE=MYLITE DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
insert into tx values (1, 'seed');
insert into tx_mylite values (1, 'mylite-seed');
start transaction;
insert into tx values (2, 'rolled-back');
update tx set title = 'seed-rolled-back' where id = 1;
rollback;
select id, title from tx order by id;
id	title
1	seed
start transaction;
insert into tx_mylite values (2, 'mylite-rolled-back');
update tx_mylite set title = 'mylite-seed-rolled-back' where id = 1;
rollback;
select id, title from tx_mylite order by id;
id	title
1	mylite-seed
start transaction;
insert into tx values (2, 'committed');
update tx set title = 'seed-committed' where id = 1;
commit;
select id, title from tx order by id;
id	title
1	seed-committed
2	committed
start transaction;
insert into tx_mylite values (2, 'mylite-committed');
update tx_mylite set title = 'mylite-seed-committed' where id = 1;
commit;
select id, title from tx_mylite order by id;
id	title
1	mylite-seed-committed
2	mylite-committed
start transaction;
insert into tx values (3, 'savepoint-kept');
savepoint after_insert;
update tx set title = 'savepoint-undone' where id = 2;
rollback to savepoint after_insert;
select id, title from tx order by id;
id	title
1	seed-committed
2	committed
3	savepoint-kept
release savepoint after_insert;
commit;
select id, title from tx order by id;
id	title
1	seed-committed
2	committed
3	savepoint-kept
drop database mylite_mtr_transactions;
